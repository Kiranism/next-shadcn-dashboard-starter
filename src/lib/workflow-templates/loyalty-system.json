{
  "name": "Система лояльности",
  "description": "Программа лояльности: проверка по Telegram, активация существующего аккаунта сайта по контакту, начисление приветственных бонусов из настроек проекта при активации, реферальная программа и личный кабинет пользователя.",
  "nodes": [
    {
      "id": "start-trigger",
      "type": "trigger.command",
      "position": {
        "x": 0,
        "y": 300
      },
      "data": {
        "label": "Команда /start",
        "config": {
          "trigger.command": {
            "command": "/start"
          }
        }
      }
    },
    {
      "id": "check-telegram-user",
      "type": "action.database_query",
      "position": {
        "x": 380,
        "y": 300
      },
      "data": {
        "label": "Проверить по Telegram ID",
        "config": {
          "action.database_query": {
            "query": "check_user_by_telegram",
            "assignTo": "telegramUser",
            "parameters": {
              "projectId": "{{projectId}}",
              "telegramId": "{{telegram.userId}}"
            }
          }
        }
      }
    },
    {
      "id": "cond-user-found",
      "type": "condition",
      "position": {
        "x": 760,
        "y": 300
      },
      "data": {
        "label": "Пользователь найден?",
        "config": {
          "condition": {
            "operator": "is_not_empty",
            "variable": "telegramUser"
          }
        }
      }
    },
    {
      "id": "cond-user-active",
      "type": "condition",
      "position": {
        "x": 1140,
        "y": 120
      },
      "data": {
        "label": "Пользователь активен?",
        "config": {
          "condition": {
            "operator": "equals",
            "variable": "telegramUser.isActive",
            "value": true
          }
        }
      }
    },
    {
      "id": "msg-active-user",
      "type": "message",
      "position": {
        "x": 1520,
        "y": 120
      },
      "data": {
        "label": "Профиль пользователя",
        "config": {
          "message": {
            "text": "👋 Добро пожаловать назад, <b>{user.firstName}</b>!\n\n💵 Ваш баланс бонусов: <b>{user.balanceFormatted}</b>\n📊 Всего заработано: <b>{user.totalEarnedFormatted}</b>\n🛒 Потрачено: <b>{user.totalSpentFormatted}</b>\n🏆 Истекает в ближайшие 30 дней: <b>{user.expiringBonusesFormatted}</b>\n\nВыберите действие:",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [
                  {
                    "text": "💰 Баланс",
                    "callback_data": "menu_balance"
                  },
                  {
                    "text": "📜 История",
                    "callback_data": "menu_history"
                  }
                ],
                [
                  {
                    "text": "🏆 Уровень",
                    "callback_data": "menu_level"
                  },
                  {
                    "text": "👥 Рефералы",
                    "callback_data": "menu_referrals"
                  }
                ],
                [
                  {
                    "text": "🔗 Пригласить",
                    "callback_data": "menu_invite"
                  },
                  {
                    "text": "❓ Помощь",
                    "callback_data": "menu_help"
                  }
                ]
              ]
            }
          }
        }
      }
    },
    {
      "id": "msg-request-contact",
      "type": "message",
      "position": {
        "x": 1140,
        "y": 480
      },
      "data": {
        "label": "Запрос контакта",
        "config": {
          "message": {
            "text": "🎁 Добро пожаловать в программу лояльности!\n\n📱 Чтобы создать аккаунт или привязать существующий, поделитесь номером телефона кнопкой ниже.",
            "waitForInput": true,
            "keyboard": {
              "type": "reply",
              "buttons": [
                [
                  {
                    "text": "📱 Поделиться контактом",
                    "request_contact": true
                  }
                ]
              ]
            }
          }
        }
      }
    },
    {
      "id": "db-check-contact",
      "type": "action.database_query",
      "position": {
        "x": 1520,
        "y": 480
      },
      "data": {
        "label": "Проверить по контакту",
        "config": {
          "action.database_query": {
            "query": "check_user_by_contact",
            "assignTo": "contactUser",
            "parameters": {
              "projectId": "{{projectId}}",
              "phone": "{{contactReceived.phoneNumber}}",
              "email": "{{telegram.message.text}}",
              "telegramId": "{{telegram.userId}}"
            }
          }
        }
      }
    },
    {
      "id": "cond-contact-found",
