      "data": {
        "label": "Требуется регистрация",
        "config": {
          "message": {
            "text": "🌐 Аккаунт с вашим номером телефона не найден.\n\n📝 Пожалуйста, сначала зарегистрируйтесь на нашем сайте:\nhttps://{project.domain}\n\n✨ После регистрации вернитесь в бот и поделитесь контактом снова для активации аккаунта и получения бонусов!",
            "parseMode": "HTML",
            "keyboard": {
              "type": "remove"
            }
          }
        }
      }
    },
    {
      "id": "cond-has-telegram-id",
