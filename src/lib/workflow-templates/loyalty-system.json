{
  "name": "Система лояльности",
  "description": "Программа лояльности: проверка по Telegram, активация существующего аккаунта сайта по контакту, начисление приветственных бонусов из настроек проекта при активации.",
  "nodes": [
    {
      "id": "start-trigger",
      "type": "trigger.command",
      "position": { "x": 0, "y": 300 },
      "data": {
        "label": "Команда /start",
        "config": {
          "trigger.command": {
            "command": "/start"
          }
        }
      }
    },
    {
      "id": "check-telegram-user",
      "type": "action.database_query",
      "position": { "x": 380, "y": 300 },
      "data": {
        "label": "Проверить по Telegram ID",
        "config": {
          "action.database_query": {
            "query": "check_user_by_telegram",
            "assignTo": "telegramUser",
            "parameters": {
              "projectId": "{{projectId}}",
              "telegramId": "{{telegram.userId}}"
            }
          }
        }
      }
    },
    {
      "id": "cond-user-found",
      "type": "condition",
      "position": { "x": 760, "y": 300 },
      "data": {
        "label": "Пользователь найден?",
        "config": {
          "condition": {
            "operator": "is_not_empty",
            "variable": "telegramUser"
          }
        }
      }
    },
    {
      "id": "cond-user-active",
      "type": "condition",
      "position": { "x": 1140, "y": 120 },
      "data": {
        "label": "Пользователь активен?",
        "config": {
          "condition": {
            "operator": "equals",
            "variable": "telegramUser.isActive",
            "value": true
          }
        }
      }
    },
    {
      "id": "msg-active-user",
      "type": "message",
      "position": { "x": 1520, "y": 120 },
      "data": {
        "label": "Профиль пользователя",
        "config": {
          "message": {
            "text": "👋 Добро пожаловать, <b>{user.firstName}</b>!\n\n💵 Баланс бонусов: <b>{user.balanceFormatted}</b>\n📊 Всего заработано: <b>{user.totalEarnedFormatted}</b>\n🛒 Потрачено: <b>{user.totalSpentFormatted}</b>\n🏆 Истекает в ближайшие 30 дней: <b>{user.expiringBonusesFormatted}</b>\n\n✨ Спасибо, что с нами!",
            "parseMode": "HTML"
          }
        }
      }
    },
    {
      "id": "msg-request-contact",
      "type": "message",
      "position": { "x": 1140, "y": 480 },
      "data": {
        "label": "Запрос контакта",
        "config": {
          "message": {
            "text": "🎁 Добро пожаловать в программу лояльности!\n\n📱 Чтобы создать аккаунт или привязать существующий, поделитесь номером телефона кнопкой ниже.",
            "waitForInput": true,
            "keyboard": {
              "type": "reply",
              "buttons": [
                [
                  {
                    "text": "📱 Поделиться контактом",
                    "request_contact": true
                  }
                ]
              ]
            }
          }
        }
      }
    },
    {
      "id": "db-check-contact",
      "type": "action.database_query",
      "position": { "x": 1520, "y": 480 },
      "data": {
        "label": "Проверить по контакту",
        "config": {
          "action.database_query": {
            "query": "check_user_by_contact",
            "assignTo": "contactUser",
            "parameters": {
              "projectId": "{{projectId}}",
              "phone": "{{contactReceived.phoneNumber}}",
              "email": "{{telegram.message.text}}",
              "telegramId": "{{telegram.userId}}"
            }
          }
        }
      }
    },
    {
      "id": "cond-contact-found",
      "type": "condition",
      "position": { "x": 1900, "y": 480 },
      "data": {
        "label": "Аккаунт найден?",
        "config": {
          "condition": {
            "operator": "is_not_empty",
            "variable": "contactUser"
          }
        }
      }
    },
    {
      "id": "msg-register-on-site",
      "type": "message",
      "position": { "x": 2280, "y": 640 },
      "data": {
        "label": "Требуется регистрация",
        "config": {
          "message": {
            "text": "🌐 Аккаунт с вашим номером телефона не найден.\n\n📝 Пожалуйста, сначала зарегистрируйтесь на нашем сайте:\nhttps://{project.domain}\n\n✨ После регистрации вернитесь в бот и поделитесь контактом снова для активации аккаунта и получения бонусов!",
            "parseMode": "HTML"
          }
        }
      }
    },
    {
      "id": "cond-has-telegram-id",
      "type": "condition",
      "position": { "x": 2280, "y": 360 },
      "data": {
        "label": "У аккаунта есть Telegram?",
        "config": {
          "condition": {
            "operator": "is_not_empty",
            "variable": "contactUser.telegramId"
          }
        }
      }
    },
    {
      "id": "cond-other-telegram",
      "type": "condition",
      "position": { "x": 2660, "y": 280 },
      "data": {
        "label": "Привязан другой Telegram?",
        "config": {
          "condition": {
            "operator": "not_equals",
            "variable": "contactUser.telegramId",
            "value": "{{telegram.userId}}"
          }
        }
      }
    },
    {
      "id": "msg-already-linked",
      "type": "message",
      "position": { "x": 2660, "y": 200 },
      "data": {
        "label": "Уже привязан другой Telegram",
        "config": {
          "message": {
            "text": "ℹ️ К этому аккаунту уже привязан другой Telegram.\n\nЕсли это ошибка, напишите в поддержку магазина.",
            "parseMode": "HTML"
          }
        }
      }
    },
    {
      "id": "db-activate-user",
      "type": "action.database_query",
      "position": { "x": 2660, "y": 480 },
      "data": {
        "label": "Активировать и привязать Telegram",
        "config": {
          "action.database_query": {
            "query": "activate_user",
            "parameters": {
              "userId": "{{contactUser.id}}",
              "telegramId": "{{telegram.userId}}",
              "telegramUsername": "{{telegram.username}}",
              "phone": "{{contactReceived.phoneNumber}}"
            }
          }
        }
      }
    },
    {
      "id": "db-check-welcome-bonus",
      "type": "action.database_query",
      "position": { "x": 3040, "y": 480 },
      "data": {
        "label": "Проверить приветственные бонусы",
        "config": {
          "action.database_query": {
            "query": "check_welcome_bonus",
            "assignTo": "hasWelcomeBonus",
            "parameters": {
              "userId": "{{contactUser.id}}"
            }
          }
        }
      }
    },
    {
      "id": "cond-welcome-bonus-exists",
      "type": "condition",
      "position": { "x": 3420, "y": 480 },
      "data": {
        "label": "Есть приветственные бонусы?",
        "config": {
          "condition": {
            "operator": "equals",
            "variable": "hasWelcomeBonus",
            "value": false
          }
        }
      }
    },
    {
      "id": "db-add-welcome-new",
      "type": "action.database_query",
      "position": { "x": 3800, "y": 380 },
      "data": {
        "label": "Начислить приветственные бонусы",
        "config": {
          "action.database_query": {
            "query": "add_bonus",
            "parameters": {
              "userId": "{{contactUser.id}}",
              "amount": "{{project.welcomeBonus}}",
              "type": "WELCOME",
              "description": "Приветственные бонусы за регистрацию в боте",
              "expiresAt": ""
            }
          }
        }
      }
    },
    {
      "id": "msg-success-activated",
      "type": "message",
      "position": { "x": 4180, "y": 480 },
      "data": {
        "label": "Успешная активация",
        "config": {
          "message": {
            "text": "🎉 Аккаунт активирован, Telegram привязан!\n\n💰 Приветственные бонусы (если включены в проекте) начислены автоматически.\n\nПриятных покупок!",
            "parseMode": "HTML"
          }
        }
      }
    },
    {
      "id": "flow-end",
      "type": "flow.end",
      "position": { "x": 4560, "y": 300 },
      "data": {
        "label": "Завершение",
        "config": {
          "flow.end": {
            "success": true
          }
        }
      }
    }
  ],
  "connections": [
    {
      "id": "e-start-check",
      "type": "default",
      "source": "start-trigger",
      "target": "check-telegram-user"
    },
    {
      "id": "e-check-found",
      "type": "default",
      "source": "check-telegram-user",
      "target": "cond-user-found"
    },
    {
      "id": "e-found-active",
      "type": "default",
      "source": "cond-user-found",
      "target": "cond-user-active",
      "sourceHandle": "true"
    },
    {
      "id": "e-found-contact",
      "type": "default",
      "source": "cond-user-found",
      "target": "msg-request-contact",
      "sourceHandle": "false"
    },
    {
      "id": "e-active-profile",
      "type": "default",
      "source": "cond-user-active",
      "target": "msg-active-user",
      "sourceHandle": "true"
    },
    {
      "id": "e-active-contact",
      "type": "default",
      "source": "cond-user-active",
      "target": "msg-request-contact",
      "sourceHandle": "false"
    },
    {
      "id": "e-profile-end",
      "type": "default",
      "source": "msg-active-user",
      "target": "flow-end"
    },
    {
      "id": "e-msg-check-contact",
      "type": "default",
      "source": "msg-request-contact",
      "target": "db-check-contact"
    },
    {
      "id": "e-check-contact-cond",
      "type": "default",
      "source": "db-check-contact",
      "target": "cond-contact-found"
    },
    {
      "id": "e-contact-found-has-tg",
      "type": "default",
      "source": "cond-contact-found",
      "target": "cond-has-telegram-id",
      "sourceHandle": "true"
    },
    {
      "id": "e-contact-notfound-register",
      "type": "default",
      "source": "cond-contact-found",
      "target": "msg-register-on-site",
      "sourceHandle": "false"
    },
    {
      "id": "e-register-end",
      "type": "default",
      "source": "msg-register-on-site",
      "target": "flow-end"
    },
    {
      "id": "e-has-tg-other",
      "type": "default",
      "source": "cond-has-telegram-id",
      "target": "cond-other-telegram",
      "sourceHandle": "true"
    },
    {
      "id": "e-has-tg-activate",
      "type": "default",
      "source": "cond-has-telegram-id",
      "target": "db-activate-user",
      "sourceHandle": "false"
    },
    {
      "id": "e-other-tg-already",
      "type": "default",
      "source": "cond-other-telegram",
      "target": "msg-already-linked",
      "sourceHandle": "true"
    },
    {
      "id": "e-other-tg-activate",
      "type": "default",
      "source": "cond-other-telegram",
      "target": "db-activate-user",
      "sourceHandle": "false"
    },
    {
      "id": "e-already-end",
      "type": "default",
      "source": "msg-already-linked",
      "target": "flow-end"
    },
    {
      "id": "e-activate-checkbonus",
      "type": "default",
      "source": "db-activate-user",
      "target": "db-check-welcome-bonus"
    },
    {
      "id": "e-checkbonus-cond",
      "type": "default",
      "source": "db-check-welcome-bonus",
      "target": "cond-welcome-bonus-exists"
    },
    {
      "id": "e-cond-addbonus",
      "type": "default",
      "source": "cond-welcome-bonus-exists",
      "target": "db-add-welcome-new",
      "sourceHandle": "true"
    },
    {
      "id": "e-cond-success",
      "type": "default",
      "source": "cond-welcome-bonus-exists",
      "target": "msg-success-activated",
      "sourceHandle": "false"
    },
    {
      "id": "e-addbonus-success",
      "type": "default",
      "source": "db-add-welcome-new",
      "target": "msg-success-activated"
    },
    {
      "id": "e-success-act-end",
      "type": "default",
      "source": "msg-success-activated",
      "target": "flow-end"
    }
  ],
  "variables": [
    {
      "name": "telegramUser",
      "type": "object",
      "description": "Результат check_user_by_telegram"
    },
    {
      "name": "contactUser",
      "type": "object",
      "description": "Результат check_user_by_contact"
    },
    {
      "name": "hasWelcomeBonus",
      "type": "boolean",
      "description": "Есть ли приветственные бонусы",
      "defaultValue": false
    }
  ],
  "settings": {
    "maxExecutionTime": 60000,
    "retryAttempts": 3
  }
}
