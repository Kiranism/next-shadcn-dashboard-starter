    {
      "id": "db-add-welcome-new",
      "type": "action.database_query",
      "position": {
        "x": 3800,
        "y": 380
      },
      "data": {
        "label": "Начислить приветственные бонусы",
        "config": {
          "action.database_query": {
            "query": "add_bonus",
            "parameters": {
              "userId": "{{contactUser.id}}",
              "amount": "{{project.welcomeBonus}}",
              "type": "WELCOME",
              "description": "Приветственные бонусы за регистрацию в боте",
              "expiresAt": ""
            }
          }
        }
      }
    },
