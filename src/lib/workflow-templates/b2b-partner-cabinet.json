          "message": {
            "text": "<b>🏆 Ваш уровень:</b> {user.currentLevel}\n\n<b>📊 Прогресс:</b> {user.progressBar} ({user.progressPercent}%)\n\n<b>💰 Бонусный %:</b> {user.levelBonusPercent}%\n<b>Следующий уровень:</b> {user.nextLevelName}",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
