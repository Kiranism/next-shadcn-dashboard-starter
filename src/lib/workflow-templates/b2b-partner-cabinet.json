      "id": "show-history-list",
      "type": "message",
      "position": { "x": 1140, "y": 920 },
      "data": {
        "label": "Показать историю",
        "config": {
          "message": {
            "text": "<b>📜 История операций</b>\n\n<b>Последние 10 операций:</b>\n\n{transactions.formatted}\n\n💡 Полная история — в личном кабинете на сайте.",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
