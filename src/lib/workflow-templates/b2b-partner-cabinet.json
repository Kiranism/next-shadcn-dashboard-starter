  "connections": [
    {
      "id": "e-start-check",
      "type": "default",
      "source": "start-trigger",
      "target": "check-telegram-user"
    },
    {
      "id": "e-check-found",
      "type": "default",
      "source": "check-telegram-user",
      "target": "cond-user-found"
    },
    {
      "id": "e-found-active",
      "type": "default",
      "source": "cond-user-found",
      "target": "cond-user-active",
      "sourceHandle": "true"
    },
    {
      "id": "e-found-contact",
      "type": "default",
      "source": "cond-user-found",
      "target": "msg-request-contact",
      "sourceHandle": "false"
    },
    {
      "id": "e-active-b2b",
      "type": "default",
      "source": "cond-user-active",
      "target": "msg-remove-keyboard",
      "sourceHandle": "true"
