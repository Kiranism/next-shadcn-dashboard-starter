{
  "name": "B2B Партнёр",
  "description": "B2B кабинет партнёра v1.2 — привязка Telegram по телефону, меню по роли, партнёрские callback-ветки и базовое меню лояльности. Требует enablePartnerRoles.",
  "nodes": [
    {
      "id": "start-trigger",
      "type": "trigger.command",
      "position": { "x": 0, "y": 320 },
      "data": {
        "label": "Команда /start",
        "config": {
          "trigger.command": {
            "command": "/start"
          }
        }
      }
    },
    {
      "id": "check-telegram-user",
      "type": "action.database_query",
      "position": { "x": 380, "y": 320 },
      "data": {
        "label": "Проверить по Telegram ID",
        "config": {
          "action.database_query": {
            "query": "check_user_by_telegram",
            "assignTo": "telegramUser",
            "parameters": {
              "projectId": "{{projectId}}",
              "telegramId": "{{telegram.userId}}"
            }
          }
        }
      }
    },
    {
      "id": "cond-user-found",
      "type": "condition",
      "position": { "x": 760, "y": 320 },
      "data": {
        "label": "Пользователь найден?",
        "config": {
          "condition": {
            "operator": "is_not_empty",
            "variable": "telegramUser"
          }
        }
      }
    },
    {
      "id": "cond-user-active",
      "type": "condition",
      "position": { "x": 1140, "y": 240 },
      "data": {
        "label": "Telegram привязан и активен?",
        "config": {
          "condition": {
            "operator": "equals",
            "variable": "telegramUser.isActive",
            "value": true
          }
        }
      }
    },
    {
      "id": "msg-request-contact",
      "type": "message",
      "position": { "x": 1140, "y": 480 },
      "data": {
        "label": "Запрос контакта",
        "config": {
          "message": {
            "text": "🎁 <b>Добро пожаловать!</b>\n\n📱 Чтобы открыть личный кабинет, поделитесь номером телефона — мы найдём ваш аккаунт с сайта и привяжем Telegram.\n\nЕсли вы ещё не регистрировались на сайте, сначала оформите заказ или регистрацию на сайте.",
            "parseMode": "HTML",
            "keyboard": {
              "type": "reply",
              "buttons": [
                [{ "text": "📱 Поделиться контактом", "request_contact": true }]
              ]
            }
          }
        }
      }
    },
    {
      "id": "contact-trigger",
      "type": "trigger.contact",
      "position": { "x": 0, "y": 520 },
      "data": {
        "label": "Получен контакт",
        "config": {
          "trigger.contact": {}
        }
      }
    },
    {
      "id": "db-check-contact",
      "type": "action.database_query",
      "position": { "x": 380, "y": 520 },
      "data": {
        "label": "Найти по телефону",
        "config": {
          "action.database_query": {
            "query": "check_user_by_contact",
            "assignTo": "contactUser",
            "parameters": {
              "projectId": "{{projectId}}",
              "phone": "{{contactReceived.phoneNumber}}"
            }
          }
        }
      }
    },
    {
      "id": "cond-contact-found",
      "type": "condition",
      "position": { "x": 760, "y": 520 },
      "data": {
        "label": "Аккаунт на сайте найден?",
        "config": {
          "condition": {
            "operator": "is_not_empty",
            "variable": "contactUser"
          }
        }
      }
    },
    {
      "id": "cond-telegram-linked",
      "type": "condition",
      "position": { "x": 1140, "y": 520 },
      "data": {
        "label": "Telegram уже занят?",
        "config": {
          "condition": {
            "operator": "is_not_empty",
            "variable": "contactUser.telegramId"
          }
        }
      }
    },
    {
      "id": "msg-already-linked",
      "type": "message",
      "position": { "x": 1520, "y": 420 },
      "data": {
        "label": "Другой Telegram привязан",
        "config": {
          "message": {
            "text": "ℹ️ К этому телефону уже привязан другой Telegram. Обратитесь в поддержку магазина.",
            "parseMode": "HTML"
          }
        }
      }
    },
    {
      "id": "msg-contact-not-found",
      "type": "message",
      "position": { "x": 1140, "y": 680 },
      "data": {
        "label": "Аккаунт не найден",
        "config": {
          "message": {
            "text": "⚠️ Аккаунт с этим телефоном не найден.\n\nСначала зарегистрируйтесь на сайте (форма или заказ), затем снова нажмите /start и поделитесь контактом.",
            "parseMode": "HTML"
          }
        }
      }
    },
    {
      "id": "db-activate-user",
      "type": "action.database_query",
      "position": { "x": 1520, "y": 560 },
      "data": {
        "label": "Привязать Telegram",
        "config": {
          "action.database_query": {
            "query": "activate_user",
            "parameters": {
              "userId": "{{contactUser.id}}",
              "telegramId": "{{telegram.userId}}",
              "telegramUsername": "{{telegram.username}}"
            }
          }
        }
      }
    },
    {
      "id": "msg-remove-keyboard",
      "type": "message",
      "position": { "x": 1520, "y": 320 },
      "data": {
        "label": "Убрать reply-клавиатуру",
        "config": {
          "message": {
            "text": "✅ Telegram привязан. Открываю меню…",
            "parseMode": "HTML",
            "keyboard": {
              "type": "remove"
            }
          }
        }
      }
    },
    {
      "id": "cond-is-director",
      "type": "condition",
      "position": { "x": 380, "y": 80 },
      "data": {
        "label": "Роль = DIRECTOR?",
        "config": {
          "condition": {
            "operator": "equals",
            "variable": "user.partnerRole",
            "value": "DIRECTOR"
          }
        }
      }
    },
    {
      "id": "cond-is-manager",
      "type": "condition",
      "position": { "x": 760, "y": 240 },
      "data": {
        "label": "Роль = MANAGER?",
        "config": {
          "condition": {
            "operator": "equals",
            "variable": "user.partnerRole",
            "value": "MANAGER"
          }
        }
      }
    },
    {
      "id": "cond-is-trainer",
      "type": "condition",
      "position": { "x": 1140, "y": 400 },
      "data": {
        "label": "Роль = TRAINER?",
        "config": {
          "condition": {
            "operator": "equals",
            "variable": "user.partnerRole",
            "value": "TRAINER"
          }
        }
      }
    },
    {
      "id": "menu-director",
      "type": "message",
      "position": { "x": 760, "y": 80 },
      "data": {
        "label": "Меню директора",
        "config": {
          "message": {
            "text": "🏆 <b>Кабинет директора</b>\n\nПривет, {user.firstName}!\n\n👥 В команде: <b>{user.teamSize}</b>\n💼 Комиссия в этом месяце: <b>{user.commissionThisMonthFormatted}</b>\n💰 Всего заработано: <b>{user.totalCommissionEarnedFormatted}</b>\n\nВыберите действие:",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [
                  { "text": "📊 Сводка по организации", "callback_data": "partner_org_summary" },
                  { "text": "👥 Моя команда", "callback_data": "partner_team_page:0" },
                  { "text": "📥 Заявки", "callback_data": "partner_requests" }
                ],
                [
                  { "text": "🔗 Моя ссылка", "callback_data": "partner_link" },
                  { "text": "💵 Мои выплаты", "callback_data": "partner_payouts" }
                ],
                [
                  { "text": "💰 Баланс", "callback_data": "menu_balance" },
                  { "text": "📜 История", "callback_data": "menu_history" }
                ]
              ]
            }
          }
        }
      }
    },
    {
      "id": "menu-manager",
      "type": "message",
      "position": { "x": 1140, "y": 240 },
      "data": {
        "label": "Меню менеджера",
        "config": {
          "message": {
            "text": "👥 <b>Кабинет менеджера</b>\n\nПривет, {user.firstName}!\n\n👤 Под вами: <b>{user.directReferralsCount}</b> прямых · <b>{user.indirectReferralsCount}</b> косвенных\n💼 Комиссия в этом месяце: <b>{user.commissionThisMonthFormatted}</b>\n💰 Всего заработано: <b>{user.totalCommissionEarnedFormatted}</b>\n\nВыберите действие:",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [
                  { "text": "👥 Моя команда", "callback_data": "partner_team_page:0" },
                  { "text": "📥 Заявки", "callback_data": "partner_requests" }
                ],
                [
                  { "text": "🔗 Моя ссылка", "callback_data": "partner_link" },
                  { "text": "💵 Мои выплаты", "callback_data": "partner_payouts" }
                ],
                [
                  { "text": "💰 Баланс", "callback_data": "menu_balance" },
                  { "text": "📜 История", "callback_data": "menu_history" }
                ]
              ]
            }
          }
        }
      }
    },
    {
      "id": "menu-trainer",
      "type": "message",
      "position": { "x": 1520, "y": 400 },
      "data": {
        "label": "Меню тренера",
        "config": {
          "message": {
            "text": "🏃 <b>Кабинет тренера</b>\n\nПривет, {user.firstName}!\n\n👤 Клиентов: <b>{user.directReferralsCount}</b>\n💼 Комиссия в этом месяце: <b>{user.commissionThisMonthFormatted}</b>\n💰 Всего заработано: <b>{user.totalCommissionEarnedFormatted}</b>\n\nВыберите действие:",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [
                  { "text": "🔗 Моя ссылка", "callback_data": "partner_link" }
                ],
                [
                  { "text": "👤 Мои клиенты", "callback_data": "partner_team_page:0" },
                  { "text": "💵 Мои выплаты", "callback_data": "partner_payouts" }
                ],
                [
                  { "text": "💰 Баланс", "callback_data": "menu_balance" },
                  { "text": "📜 История", "callback_data": "menu_history" }
                ]
              ]
            }
          }
        }
      }
    },
    {
      "id": "menu-client",
      "type": "message",
      "position": { "x": 1520, "y": 560 },
      "data": {
        "label": "Меню клиента",
        "config": {
          "message": {
            "text": "👋 <b>Здравствуйте, {user.firstName}!</b>\n\n💵 Баланс: <b>{user.balanceFormatted}</b>\n🏆 Уровень: <b>{user.currentLevel}</b>\n📈 Заработано бонусов: <b>{user.totalEarnedFormatted}</b>\n\nВыберите действие:",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [
                  { "text": "💰 Баланс", "callback_data": "menu_balance" },
                  { "text": "📜 История", "callback_data": "menu_history" }
                ],
                [
                  { "text": "🏆 Уровень", "callback_data": "menu_level" },
                  { "text": "👥 Реферальная программа", "callback_data": "menu_referrals" }
                ],
                [
                  { "text": "❓ Помощь", "callback_data": "menu_help" }
                ]
              ]
            }
          }
        }
      }
    },
    {
      "id": "trigger-cb-org-summary",
      "type": "trigger.callback",
      "position": { "x": 0, "y": 800 },
      "data": {
        "label": "Сводка организации (callback)",
        "config": {
          "trigger.callback": {
            "callbackData": "partner_org_summary"
          }
        }
      }
    },
    {
      "id": "action-org-summary",
      "type": "action.partner_org_summary",
      "position": { "x": 380, "y": 800 },
      "data": {
        "label": "Показать сводку",
        "config": {
          "action.partner_org_summary": {
            "topLimit": 5
          }
        }
      }
    },
    {
      "id": "trigger-cb-team",
      "type": "trigger.callback",
      "position": { "x": 0, "y": 920 },
      "data": {
        "label": "Команда (callback)",
        "config": {
          "trigger.callback": {
            "callbackData": "partner_team_page"
          }
        }
      }
    },
    {
      "id": "action-team",
      "type": "action.partner_team",
      "position": { "x": 380, "y": 920 },
      "data": {
        "label": "Показать команду",
        "config": {
          "action.partner_team": {
            "pageSize": 5,
            "page": "{{telegram.callback.params[0]}}"
          }
        }
      }
    },
    {
      "id": "trigger-cb-link",
      "type": "trigger.callback",
      "position": { "x": 0, "y": 1040 },
      "data": {
        "label": "Реф. ссылка (callback)",
        "config": {
          "trigger.callback": {
            "callbackData": "partner_link"
          }
        }
      }
    },
    {
      "id": "action-link",
      "type": "action.partner_link",
      "position": { "x": 380, "y": 1040 },
      "data": {
        "label": "Показать реф. ссылку",
        "config": {
          "action.partner_link": {
            "additionalParams": {
              "utm_source": "partner-bot"
            }
          }
        }
      }
    },
    {
      "id": "trigger-cb-payouts",
      "type": "trigger.callback",
      "position": { "x": 0, "y": 1160 },
      "data": {
        "label": "Выплаты (callback)",
        "config": {
          "trigger.callback": {
            "callbackData": "partner_payouts"
          }
        }
      }
    },
    {
      "id": "action-payouts",
      "type": "action.partner_payouts",
      "position": { "x": 380, "y": 1160 },
      "data": {
        "label": "История выплат",
        "config": {
          "action.partner_payouts": {
            "limit": 20
          }
        }
      }
    },
    {
      "id": "trigger-cb-subject",
      "type": "trigger.callback",
      "position": { "x": 0, "y": 1280 },
      "data": {
        "label": "Стата подопечного (callback)",
        "config": {
          "trigger.callback": {
            "callbackData": "partner_subject"
          }
        }
      }
    },
    {
      "id": "action-subject-stats",
      "type": "action.partner_subject_stats",
      "position": { "x": 380, "y": 1280 },
      "data": {
        "label": "Стата подопечного",
        "config": {
          "action.partner_subject_stats": {
            "subjectUserId": "{{telegram.callback.params[0]}}"
          }
        }
      }
    },
    {
      "id": "menu-balance-trigger",
      "type": "trigger.callback",
      "position": { "x": 760, "y": 800 },
      "data": {
        "label": "Баланс (callback)",
        "config": {
          "trigger.callback": { "callbackData": "menu_balance" }
        }
      }
    },
    {
      "id": "show-balance-details",
      "type": "message",
      "position": { "x": 1140, "y": 800 },
      "data": {
        "label": "Показать баланс",
        "config": {
          "message": {
            "text": "<b>💰 Ваш баланс бонусов</b>\n\n💵 <b>Текущий баланс:</b> {user.balanceFormatted}\n📈 <b>Всего заработано:</b> {user.totalEarnedFormatted}\n📉 <b>Всего потрачено:</b> {user.totalSpentFormatted}\n🛍️ <b>Покупок на сумму:</b> {user.totalPurchasesFormatted}",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [{ "text": "⬅️ В меню", "callback_data": "back_to_menu" }]
              ]
            }
          }
        }
      }
    },
    {
      "id": "menu-history-trigger",
      "type": "trigger.callback",
      "position": { "x": 760, "y": 920 },
      "data": {
        "label": "История (callback)",
        "config": {
          "trigger.callback": { "callbackData": "menu_history" }
        }
      }
    },
    {
      "id": "show-history-list",
      "type": "message",
      "position": { "x": 1140, "y": 920 },
      "data": {
        "label": "Показать историю",
        "config": {
          "message": {
            "text": "<b>📜 История операций</b>\n\n<b>Последние 10 операций:</b>\n\n{transactions.formatted}\n\n💡 Полная история — в личном кабинете на сайте.",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [{ "text": "⬅️ В меню", "callback_data": "back_to_menu" }]
              ]
            }
          }
        }
      }
    },
    {
      "id": "menu-level-trigger",
      "type": "trigger.callback",
      "position": { "x": 760, "y": 1040 },
      "data": {
