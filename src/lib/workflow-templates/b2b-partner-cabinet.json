    },
    {
      "id": "show-balance-details",
      "type": "message",
      "position": { "x": 1140, "y": 800 },
      "data": {
        "label": "Показать баланс",
        "config": {
          "message": {
            "text": "<b>💰 Ваш баланс бонусов</b>\n\n💵 <b>Текущий баланс:</b> {user.balanceFormatted}\n📈 <b>Всего заработано:</b> {user.totalEarnedFormatted}\n📉 <b>Всего потрачено:</b> {user.totalSpentFormatted}\n🛍️ <b>Покупок на сумму:</b> {user.totalPurchasesFormatted}",
            "parseMode": "HTML",
            "keyboard": {
              "type": "inline",
              "buttons": [
                [{ "text": "⬅️ В меню", "callback_data": "back_to_menu" }]
              ]
            }
          }
        }
      }
    },
