      "position": { "x": 380, "y": 1160 },
      "data": {
        "label": "История выплат",
        "config": {
          "action.partner_payouts": {
            "limit": 20
          }
        }
      }
    },
    {
      "id": "trigger-cb-subject",
      "type": "trigger.callback",
      "position": { "x": 0, "y": 1280 },
      "data": {
        "label": "Стата подопечного (callback)",
        "config": {
          "trigger.callback": {
            "callbackData": "partner_subject"
          }
        }
      }
    },
    {
      "id": "action-subject-stats",
      "type": "action.partner_subject_stats",
      "position": { "x": 380, "y": 1280 },
      "data": {
        "label": "Стата подопечного",
        "config": {
          "action.partner_subject_stats": {
            "subjectUserId": "{{telegram.callback.params[0]}}"
          }
        }
      }
    },
    {
      "id": "menu-balance-trigger",
      "type": "trigger.callback",
      "position": { "x": 760, "y": 800 },
      "data": {
        "label": "Баланс (callback)",
        "config": {
          "trigger.callback": { "callbackData": "menu_balance" }
        }
