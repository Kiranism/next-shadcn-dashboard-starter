  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, channelId, externalId])
  @@index([projectId, status])
  @@index([userId])
  @@index([channelId])
  @@index([lastMessageAt])
  @@map("chats")
}

model ChatMessage {
  id         String   @id @default(cuid())
  chatId     String   @map("chat_id")
  externalId String?  @map("external_id") // ID сообщения во внешней системе
  message    String   @db.Text
  direction  String // INCOMING, OUTGOING
  senderName String?  @map("sender_name")
  senderId   String?  @map("sender_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([externalId])
  @@map("chat_messages")
}

model NotificationTemplate {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  message     String   @db.Text
  imageUrl    String?  @map("image_url")
  buttons     Json?    // Array of { text, url?, callback_data? }
  parseMode   String   @default("HTML") @map("parse_mode") // HTML or Markdown
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("notification_templates")
}

// МойСклад Loyalty API Integration Models
// Архитектура: МЫ являемся API provider, МойСклад вызывает НАШИ endpoints

model MoySkladIntegration {
  id                String              @id @default(cuid())
  projectId         String              @unique @map("project_id")
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Auth token для аутентификации запросов от МойСклад
  // МойСклад отправляет этот токен в заголовке Lognex-Discount-API-Auth-Token
  authToken         String              @unique @map("auth_token") // Hashed with bcrypt
  
  // Base URL нашего Loyalty API, который мы предоставляем МойСклад
  baseUrl           String              @map("base_url") // https://gupil.ru/api/moysklad-loyalty/[projectId]
  
  // Настройки бонусной программы
  bonusPercentage   Decimal             @default(10) @map("bonus_percentage") @db.Decimal(5, 2)
  maxBonusSpend     Decimal             @default(50) @map("max_bonus_spend") @db.Decimal(5, 2) // max % оплаты бонусами
  
  // Status
  isActive          Boolean             @default(false) @map("is_active")
  lastRequestAt     DateTime?           @map("last_request_at")
  
  // Timestamps
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  
  // Relations
  apiLogs           MoySkladApiLog[]
  
  @@index([projectId])
  @@index([authToken])
  @@map("moysklad_integrations")
}

// API Log для всех запросов к Loyalty API
model MoySkladApiLog {
  id                String              @id @default(cuid())
  integrationId     String              @map("integration_id")
  integration       MoySkladIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  // Request details
  endpoint          String              @map("endpoint") // /counterparty, /retaildemand, etc.
  method            String              @map("method") // GET, POST
  requestBody       Json?               @map("request_body")
  
  // Response details
  responseStatus    Int                 @map("response_status") // HTTP status code
  responseBody      Json?               @map("response_body")
  
  // Performance
  processingTimeMs  Int                 @map("processing_time_ms")
  
  // Error details (if failed)
  errorMessage      String?             @map("error_message") @db.Text
  
  // Timestamp
  createdAt         DateTime            @default(now()) @map("created_at")
  
  @@index([integrationId, createdAt])
  @@index([endpoint])
  @@index([responseStatus])
  @@map("moysklad_api_logs")
}

// Verification codes для подтверждения списания бонусов
model VerificationCode {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String   @map("code") // 6-digit code
  expiresAt DateTime @map("expires_at") // 5 minutes from creation
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([userId, isUsed, expiresAt])
  @@map("verification_codes")
}

// InSales Integration Models
// Архитектура: REST API + Webhooks + JavaScript Widget

model InSalesIntegration {
  id                String   @id @default(cuid())
  projectId         String   @unique @map("project_id")
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // InSales API Credentials
  apiKey            String   @map("api_key")
  apiPassword       String   @map("api_password") // Encrypted
  shopDomain        String   @map("shop_domain") // myshop.myinsales.ru
  
  // Webhook Secret для валидации входящих webhooks
  webhookSecret     String   @unique @map("webhook_secret")
  
  // Настройки бонусной программы
  bonusPercent      Int      @default(10) @map("bonus_percent") // % начисления бонусов
  maxBonusSpend     Int      @default(50) @map("max_bonus_spend") // max % оплаты бонусами
  useProjectSettings Boolean @default(true) @map("use_project_settings")
  
  // Widget Settings
  widgetEnabled     Boolean  @default(true) @map("widget_enabled")
  showProductBadges Boolean  @default(true) @map("show_product_badges")
  
  // Status
  isActive          Boolean  @default(false) @map("is_active")
  lastWebhookAt     DateTime? @map("last_webhook_at")
  
  // Statistics
  totalOrders       Int      @default(0) @map("total_orders")
  totalBonusAwarded Decimal  @default(0) @map("total_bonus_awarded") @db.Decimal(10, 2)
  totalBonusSpent   Decimal  @default(0) @map("total_bonus_spent") @db.Decimal(10, 2)
  
  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  // Relations
  webhookLogs       InSalesWebhookLog[]
  
  @@index([projectId])
  @@index([webhookSecret])
  @@map("insales_integrations")
}

// Webhook Log для всех входящих webhooks от InSales
model InSalesWebhookLog {
  id            String              @id @default(cuid())
  integrationId String              @map("integration_id")
  integration   InSalesIntegration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  // Webhook details
  event         String              @map("event") // orders/create, clients/create, etc.
  payload       Json                @map("payload")
  
  // Processing details
  status        Int                 @map("status") // HTTP status code
  success       Boolean             @map("success")
  response      Json?               @map("response")
  error         String?             @map("error") @db.Text
  
  // Performance
  processingTimeMs Int?             @map("processing_time_ms")
  
  // Timestamp
  processedAt   DateTime            @default(now()) @map("processed_at")
  
  @@index([integrationId, processedAt])
  @@index([event])
  @@index([success])
  @@map("insales_webhook_logs")
}


// ============================================================================
// МойСклад Direct API Integration (Новая реализация через Bonus Transaction API)
// ============================================================================
// Архитектура: Прямая интеграция через МойСклад JSON API
// Мы используем стандартный API МойСклад для работы с бонусными операциями
// Двусторонняя синхронизация: онлайн покупки → МойСклад, офлайн покупки → наша система

enum SyncDirection {
  MOYSKLAD_TO_US    // Только из МойСклад в нашу систему
  US_TO_MOYSKLAD    // Только из нашей системы в МойСклад
  BIDIRECTIONAL     // Двусторонняя синхронизация (рекомендуется)
}

model MoySkladDirectIntegration {
  id                String              @id @default(cuid())
  projectId         String              @unique @map("project_id")
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Credentials (зашифрованы)
  accountId         String              @map("account_id") // ID организации в МойСклад
  apiToken          String              @map("api_token") // Bearer token для API (encrypted)
  bonusProgramId    String              @map("bonus_program_id") // ID программы лояльности
  
  // Настройки синхронизации
  syncDirection     SyncDirection       @default(BIDIRECTIONAL) @map("sync_direction")
  autoSync          Boolean             @default(true) @map("auto_sync")
  
  // Webhook
  webhookSecret     String?             @unique @map("webhook_secret") // Secret для валидации webhook
  
  // Статус
  isActive          Boolean             @default(false) @map("is_active")
  lastSyncAt        DateTime?           @map("last_sync_at")
  lastError         String?             @map("last_error") @db.Text
  
  // Timestamps
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  
  // Relations
  syncLogs          MoySkladDirectSyncLog[]
  
  @@index([projectId])
  @@index([webhookSecret])
  @@map("moysklad_direct_integrations")
}

// Лог синхронизации для прямой интеграции
model MoySkladDirectSyncLog {
  id            String                      @id @default(cuid())
  integrationId String                      @map("integration_id")
  integration   MoySkladDirectIntegration   @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  // Операция
  operation     String                      @map("operation") // "bonus_accrual", "bonus_spending", "balance_sync"
  direction     String                      @map("direction") // "incoming" (от МойСклад), "outgoing" (в МойСклад)
  
  // Связи
  moySkladTransactionId String?           @map("moysklad_transaction_id") // ID транзакции в МойСклад
  userId        String?                     @map("user_id") // ID пользователя в нашей системе
  user          User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Данные
  amount        Decimal?                    @db.Decimal(10, 2)
  requestData   Json?                       @map("request_data")
  responseData  Json?                       @map("response_data")
  
  // Результат
  status        String                      @map("status") // "success", "error", "pending"
  errorMessage  String?                     @map("error_message") @db.Text
  
  // Timestamp
  createdAt     DateTime                    @default(now()) @map("created_at")
  
  @@index([integrationId, createdAt])
  @@index([userId])
  @@index([status])
  @@index([moySkladTransactionId])
  @@map("moysklad_direct_sync_logs")
}
